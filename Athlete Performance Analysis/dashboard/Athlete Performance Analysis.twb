                      <formatted-text>
                        <run bold='true' fontalignment='1' fontcolor='#243b53' fontsize='36'>Athlete Performance, Recovery &amp; Risk Dashboard</run>
                      </formatted-text>
                      <zone-style>
                        <format attr='border-color' value='#000000' />
                        <format attr='border-style' value='none' />
                        <format attr='border-width' value='0' />
